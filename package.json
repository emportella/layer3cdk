{
  "name": "@applyboard/cdk-constructs",
  "version": "2.10.0",
  "description": "centralized location for managing and maintaining the CDK constructs and libraries",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "prepare": "husky && npm run build",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "npm run format -- --check",
    "format:write": "npm run format -- --write",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "npm run lint -- --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ApplyBoard/cdk-constructs.git"
  },
  "keywords": [
    "CDK"
  ],
  "author": "@ApplyBoard/rpj",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ApplyBoard/cdk-constructs/issues"
  },
  "homepage": "https://github.com/ApplyBoard/cdk-constructs#readme",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.9",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "prettier": "^3.3.2",
    "ts-jest": "^29.1.5",
    "typescript": "^5.5.1"
  },
  "dependencies": {
    "aws-cdk-lib": "2.147.1"
  }
}
