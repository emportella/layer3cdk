{
  "name": "@emportella/layer3cdk",
  "version": "0.1.0",
  "description": "Layer3CDK - L3 patterns for AWS CDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "!dist/**/*.spec.js",
    "!dist/**/*.spec.d.ts",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "prebuild": "rm -rf dist coverage",
    "prepare": "husky && npm run build",
    "build": "tsc",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "npm run format -- --check",
    "format:write": "npm run format -- --write",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "npm run lint -- --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emportella/layer3cdk.git"
  },
  "keywords": [
    "CDK"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "author": {
    "name": "emportella",
    "email": "1760584+emportella@users.noreply.github.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/emportella/layer3cdk/issues"
  },
  "homepage": "https://github.com/emportella/layer3cdk#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "workspaces": [
    "example/services"
  ],
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.37",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "aws-cdk-lib": "^2.245.0",
    "constructs": "^10.6.0"
  }
}
